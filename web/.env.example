# Supabase (클라이언트·서버 공개 가능한 키만 NEXT_PUBLIC_)
# https://supabase.com/dashboard/project/_/settings/api
# ANON 키는 JWT 한 덩어리(영문·숫자·점·하이픈만, 줄바꿈·중복 없이 Project API keys → anon public 복사)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# HiveMQ 등 — POST /api/mqtt/publish 전용(서버만, 브라우저 번들 금지)
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# 브라우저 MQTT(MqttBrowserBridge) — NEXT_PUBLIC_ 이므로 번들에 노출됨. 프로덕션은 ACL·전용 계정 권장
NEXT_PUBLIC_MQTT_BROKER_URL=
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
