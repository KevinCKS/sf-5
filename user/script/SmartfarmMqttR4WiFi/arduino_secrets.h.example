#ifndef ARDUINO_SECRETS_H
#define ARDUINO_SECRETS_H

// WiFi
#define SECRET_WIFI_SSID "YOUR_WIFI_SSID"
#define SECRET_WIFI_PASS "YOUR_WIFI_PASSWORD"

// HiveMQ Cloud: 호스트는 mqtts:// 없이 호스트명만 (예: xxx.s1.eu.hivemq.cloud)
#define SECRET_MQTT_HOST "YOUR_CLUSTER.hivemq.cloud"
#define SECRET_MQTT_USER "YOUR_DEVICE_USER"
#define SECRET_MQTT_PASS "YOUR_DEVICE_PASSWORD"

#endif
